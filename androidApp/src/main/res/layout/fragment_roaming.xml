<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_roaming"
    android:fillViewport="true">


    <FrameLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimaryDark"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_sauersack" />

        <ImageView
            android:id="@+id/close"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="right"
            android:padding="21dp"
            android:src="@drawable/img_close_roaming" />
    </FrameLayout>

    <ImageView
        android:id="@+id/roaming_icon_1"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginBottom="82dp"
        android:src="@drawable/img_roaming"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/frameLayout" />


    <TextView
        android:id="@+id/roaming_title"
        style="@style/TextViewSplash"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="@string/roaming_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/roaming_icon_1" />

    <TextView
        android:id="@+id/splash_title2"
        style="@style/TextViewSplash"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/roaming_text2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/roaming_title" />

</androidx.constraintlayout.widget.ConstraintLayout>

